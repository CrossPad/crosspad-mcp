{
  "name": "crosspad-mcp-server",
  "version": "8.1.2",
  "description": "MCP development server for CrossPad — build, test, manage apps, interact with simulator",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crosspad-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "tracer/",
    "skills/",
    ".claude-plugin/",
    ".mcp.json"
  ],
  "keywords": [
    "mcp",
    "crosspad",
    "esp32",
    "esp-idf",
    "model-context-protocol",
    "claude",
    "embedded",
    "music-controller"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/CrossPad/crosspad-mcp.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "hono": "^4.12.16",
    "ip-address": "^10.1.1",
    "postcss": "^8.5.10"
  }
}
